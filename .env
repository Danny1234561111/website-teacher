# Отключить открытие браузера автоматически
BROWSER=none

# Порт для разработки
PORT=3000

# Отключить Fast Refresh (может вызывать проблемы)
FAST_REFRESH=false

# Настройки WebSocket для hot reload
WDS_SOCKET_PORT=0

# Отключить ESLint в процессе сборки
DISABLE_ESLINT_PLUGIN=true

# Отключить проверку типов в процессе сборки
TSC_COMPILE_ON_ERROR=true

# Настройки для Windows
SKIP_PREFLIGHT_CHECK=true